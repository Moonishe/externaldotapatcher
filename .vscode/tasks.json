{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build with MSVC (Release x64)",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "cl.exe /EHsc /std:c++20 /O2 /W3 /MT /DNDEBUG /D_CONSOLE /I\"core\" core\\main.cpp core\\memory.cpp /Fe:external_patcher.exe /link kernel32.lib user32.lib psapi.lib"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": ["$msCompile"],
            "detail": "MSVC x64 release build for external_patcher"
        },
        {
            "label": "Build with GCC (MinGW-w64)",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "build_gcc.bat"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "detail": "MinGW-w64 g++ build for external_patcher"
        }
    ]
}
